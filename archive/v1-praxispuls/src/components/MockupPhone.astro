---
/**
 * Illustrated phone showing a Google-Business-profile-style card. A
 * "new 5-star review" toast drifts in on a loop — the automation story of
 * Case 2, told visually. Honest placeholder until real screenshots exist.
 */
---

<div class="phone-wrap" aria-hidden="true">
	<div class="phone float-slow">
		<div class="phone__screen">
			<div class="phone__notch"></div>
			<div class="profile">
				<div class="profile__cover"></div>
				<div class="profile__body">
					<div class="line line--name"></div>
					<div class="stars font-mono">★★★★★ <span>4,9</span></div>
					<div class="line line--meta"></div>
					<div class="profile__actions">
						<span></span>
						<span></span>
						<span class="accent"></span>
					</div>
					<div class="review">
						<span class="review__avatar"></span>
						<div class="review__lines">
							<div class="line line--rev"></div>
							<div class="line line--rev short"></div>
						</div>
					</div>
					<div class="review">
						<span class="review__avatar"></span>
						<div class="review__lines">
							<div class="line line--rev"></div>
							<div class="line line--rev short"></div>
						</div>
					</div>
				</div>
			</div>
		</div>
	</div>

	<div class="toast font-mono">★ Neue 5-Sterne-Bewertung</div>
</div>

<style>
	.phone-wrap {
		position: relative;
		width: fit-content;
		margin-inline: auto;
	}

	.phone {
		width: 172px;
	}

	.phone__screen {
		border: 3px solid color-mix(in srgb, var(--color-papier) 25%, transparent);
		border-radius: 22px;
		background: var(--color-papier);
		overflow: hidden;
		position: relative;
		box-shadow: 0 0 44px color-mix(in srgb, var(--color-puls) 14%, transparent);
	}

	.phone__notch {
		position: absolute;
		top: 6px;
		left: 50%;
		transform: translateX(-50%);
		width: 52px;
		height: 8px;
		border-radius: 999px;
		background: var(--color-tinte);
		opacity: 0.85;
	}

	.profile__cover {
		height: 64px;
		background:
			linear-gradient(color-mix(in srgb, var(--color-papier) 12%, transparent) 1px, transparent 1px),
			linear-gradient(90deg, color-mix(in srgb, var(--color-papier) 12%, transparent) 1px, transparent 1px),
			var(--color-tinte);
		background-size: 14px 14px;
	}

	.profile__body {
		padding: 12px 12px 14px;
	}

	.line {
		border-radius: 999px;
	}

	.line--name {
		height: 9px;
		width: 70%;
		background: var(--color-tinte);
	}

	.stars {
		margin-top: 8px;
		font-size: 12px;
		letter-spacing: 1px;
		color: var(--color-puls);
	}

	.stars span {
		color: color-mix(in srgb, var(--color-tinte) 80%, transparent);
		font-size: 9px;
		letter-spacing: 0;
	}

	.line--meta {
		margin-top: 7px;
		height: 5px;
		width: 55%;
		background: color-mix(in srgb, var(--color-tinte) 30%, transparent);
	}

	.profile__actions {
		display: flex;
		gap: 6px;
		margin-top: 11px;
	}

	.profile__actions span {
		flex: 1;
		height: 15px;
		border-radius: 999px;
		background: var(--color-nebel);
	}

	.profile__actions .accent {
		background: var(--color-puls);
	}

	.review {
		display: flex;
		gap: 7px;
		margin-top: 11px;
		align-items: center;
	}

	.review__avatar {
		width: 16px;
		height: 16px;
		flex-shrink: 0;
		border-radius: 999px;
		background: var(--color-nebel);
	}

	.review__lines {
		flex: 1;
	}

	.line--rev {
		height: 5px;
		width: 92%;
		background: color-mix(in srgb, var(--color-tinte) 25%, transparent);
	}

	.line--rev.short {
		margin-top: 4px;
		width: 60%;
	}

	/* Review toast: drifts in, holds, drifts out — the automation at work. */
	.toast {
		position: absolute;
		top: 18px;
		right: -46px;
		font-size: 10px;
		white-space: nowrap;
		color: var(--color-tinte);
		background: var(--color-puls);
		border-radius: 999px;
		padding: 6px 11px;
		box-shadow: 0 10px 24px -8px color-mix(in srgb, var(--color-puls) 60%, transparent);
		opacity: 0;
		animation: toast-in 6s ease-in-out infinite;
	}

	@keyframes toast-in {
		0%,
		12% {
			opacity: 0;
			transform: translateY(10px);
		}
		22%,
		68% {
			opacity: 1;
			transform: translateY(0);
		}
		80%,
		100% {
			opacity: 0;
			transform: translateY(-8px);
		}
	}

	@media (prefers-reduced-motion: reduce) {
		.toast {
			animation: none;
			opacity: 1;
			transform: none;
		}
	}

	@media (max-width: 420px) {
		.toast {
			right: -8px;
		}
	}
</style>
