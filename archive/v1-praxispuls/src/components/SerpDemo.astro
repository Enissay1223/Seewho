---
/**
 * Hero signature widget. Static markup renders the honest "before" state
 * (page 3, unranked, no reviews) so it means something with JS disabled too.
 * serp-demo.js drives the state machine (before -> beat -> after) via a
 * single [data-state] attribute; every visual change is a CSS transition on
 * opacity/transform only, so it stays smooth without measuring layout.
 */
---

<div
	class="serp-demo relative rounded-[20px] bg-papier p-5 shadow-[0_20px_50px_-18px_rgba(10,42,46,0.3)] sm:p-6"
	data-serp
	data-state="before"
	aria-label="Beispiel-Szenario: So verbessert sich die lokale Sichtbarkeit einer Praxis"
>
	<p class="font-mono text-[11px] tracking-wide text-tinte/70 uppercase">Beispiel-Szenario</p>

	<div class="mt-3 flex items-center gap-2 rounded-full bg-nebel px-4 py-2.5">
		<svg width="15" height="15" viewBox="0 0 24 24" fill="none" aria-hidden="true" class="shrink-0 text-tinte/70">
			<circle cx="11" cy="11" r="7" stroke="currentColor" stroke-width="2"></circle>
			<path d="M21 21L16.65 16.65" stroke="currentColor" stroke-width="2" stroke-linecap="round"></path>
		</svg>
		<span class="font-mono text-sm text-tinte/70" data-serp-query>zahnarzt rüttenscheid</span>
	</div>

	<ol class="mt-4 space-y-2">
		<li class="flex items-center gap-3 rounded-xl border border-tinte/10 px-4 py-3">
			<span class="font-mono text-sm text-tinte/70">1</span>
			<div class="min-w-0">
				<p class="truncate text-sm font-medium">Praxis Dr. Berger</p>
				<p class="font-mono text-xs text-tinte/70">★★★★☆ (34)</p>
			</div>
		</li>
		<li class="flex items-center gap-3 rounded-xl border border-tinte/10 px-4 py-3">
			<span class="font-mono text-sm text-tinte/70">2</span>
			<div class="min-w-0">
				<p class="truncate text-sm font-medium">Gesundheitszentrum Nord</p>
				<p class="font-mono text-xs text-tinte/70">★★★★☆ (21)</p>
			</div>
		</li>
		<li class="serp-target relative flex items-center gap-3 rounded-xl border px-4 py-3">
			<span class="font-mono text-sm text-tinte/70">3</span>
			<div class="min-w-0 flex-1">
				<p class="truncate text-sm font-medium" data-serp-name>Zahnärzte am Stadtgarten</p>
				<div class="flex items-center gap-1.5 font-mono text-xs text-tinte/70">
					<span class="serp-stars relative inline-block" aria-hidden="true">
						<span class="serp-stars__bg block">★★★★★</span>
						<span class="serp-stars__fg absolute inset-0 block overflow-hidden text-puls" data-serp-stars-fg>★★★★★</span>
					</span>
					<span data-serp-reviews>0 Bewertungen</span>
				</div>
			</div>

			<!-- Covers the slot with an honest placeholder until the "after" state. -->
			<div class="serp-veil absolute inset-0 flex items-center rounded-xl border-2 border-dashed border-tinte/20 bg-papier/95 px-4">
				<p class="font-mono text-xs text-tinte/70">Ihre Praxis erscheint hier</p>
			</div>
		</li>
	</ol>

	<p class="mt-4 font-mono text-xs text-tinte/70">
		Aktuell: <span data-serp-current-value>Seite 3 · Platz 27</span>
	</p>

	<svg class="serp-ekg mt-3 h-8 w-full" viewBox="0 0 400 60" preserveAspectRatio="none" fill="none" aria-hidden="true">
		<path
			d="M0,40 H140 L150,15 L161,54 L172,6 L183,40 H210 C250,40 252,20 290,18 C330,16 350,8 400,4"
			vector-effect="non-scaling-stroke"
		></path>
	</svg>

	<div class="mt-5 grid grid-cols-2 gap-3">
		<label class="block">
			<span class="font-mono text-[11px] tracking-wide text-tinte/70 uppercase">Fachrichtung</span>
			<select
				data-serp-fach
				class="mt-1 w-full rounded-lg border border-tinte/15 bg-papier px-2.5 py-2 font-mono text-sm"
			>
				<option value="zahnarzt">Zahnarzt</option>
				<option value="hautarzt">Hautarzt</option>
				<option value="physio">Physiotherapie</option>
				<option value="kosmetik">Kosmetik</option>
			</select>
		</label>
		<label class="block">
			<span class="font-mono text-[11px] tracking-wide text-tinte/70 uppercase">Stadtteil</span>
			<select
				data-serp-ort
				class="mt-1 w-full rounded-lg border border-tinte/15 bg-papier px-2.5 py-2 font-mono text-sm"
			>
				<option value="ruettenscheid">Rüttenscheid</option>
				<option value="innenstadt">Innenstadt</option>
				<option value="sued">Süd</option>
			</select>
		</label>
	</div>

	<p class="mt-4 text-sm text-tinte/70">
		Genau diesen Weg gehen wir. Schritt für Schritt, mit Zahlen belegt.
	</p>
</div>

<script src="../scripts/serp-demo.js"></script>

<style>
	.serp-target {
		border-color: color-mix(in srgb, var(--color-tinte) 10%, transparent);
		transition: border-color 0.6s ease;
	}

	.serp-stars__bg {
		color: color-mix(in srgb, var(--color-tinte) 25%, transparent);
	}

	.serp-stars__fg {
		transform: scaleX(0);
		transform-origin: left;
		transition: transform 0.9s cubic-bezier(0.16, 1, 0.3, 1);
		white-space: nowrap;
	}

	.serp-veil {
		transition:
			opacity 0.6s ease,
			transform 0.6s ease;
	}

	.serp-ekg path {
		stroke: var(--color-puls);
		stroke-width: 2.5;
		stroke-linecap: round;
		stroke-linejoin: round;
		stroke-dasharray: 620;
		stroke-dashoffset: 620;
		transition: stroke-dashoffset 1.1s ease-out;
	}

	.serp-demo[data-state="beat"] .serp-ekg path {
		stroke-dashoffset: 420;
		transition-duration: 0.5s;
	}

	.serp-demo[data-state="after"] .serp-target {
		border-color: var(--color-puls);
	}

	.serp-demo[data-state="after"] .serp-veil {
		opacity: 0;
		transform: translateY(-4px);
		pointer-events: none;
	}

	.serp-demo[data-state="after"] .serp-ekg path {
		stroke-dashoffset: 0;
	}
</style>
