---
/**
 * Illustrated phone showing a Google-Business-profile-style card with a
 * "new 5-star review" toast on a loop — the automation story, told visually.
 * Honest placeholder until real screenshots exist.
 */
---

<div class="phone-wrap" aria-hidden="true">
	<div class="phone">
		<div class="phone__screen">
			<div class="phone__notch"></div>
			<div class="profile">
				<div class="profile__cover"></div>
				<div class="profile__body">
					<div class="line line--name"></div>
					<div class="stars font-mono">5 Sterne <span>4,9</span></div>
					<div class="line line--meta"></div>
					<div class="profile__actions">
						<span></span>
						<span></span>
						<span class="accent"></span>
					</div>
					<div class="review">
						<span class="review__avatar"></span>
						<div class="review__lines">
							<div class="line line--rev"></div>
							<div class="line line--rev short"></div>
						</div>
					</div>
					<div class="review">
						<span class="review__avatar"></span>
						<div class="review__lines">
							<div class="line line--rev"></div>
							<div class="line line--rev short"></div>
						</div>
					</div>
				</div>
			</div>
		</div>
	</div>

	<div class="toast font-mono">Neue 5-Sterne-Bewertung</div>
</div>

<style>
	.phone-wrap {
		position: relative;
		width: fit-content;
		margin-inline: auto;
		--mock-paper: #fffaf2;
		--mock-ink: #243229;
		--mock-muted: rgba(36, 50, 41, 0.28);
	}

	.phone {
		width: 176px;
	}

	.phone__screen {
		border: 3px solid rgba(36, 50, 41, 0.1);
		border-radius: 22px;
		background: var(--mock-paper);
		overflow: hidden;
		position: relative;
		box-shadow: 0 28px 70px -48px rgba(65, 49, 35, 0.5);
	}

	.phone__notch {
		position: absolute;
		top: 6px;
		left: 50%;
		transform: translateX(-50%);
		width: 52px;
		height: 8px;
		border-radius: 999px;
		background: var(--mock-ink);
		opacity: 0.85;
	}

	.profile__cover {
		height: 64px;
		background:
			linear-gradient(rgba(255, 255, 255, 0.42) 1px, transparent 1px),
			linear-gradient(90deg, rgba(255, 255, 255, 0.42) 1px, transparent 1px),
			linear-gradient(135deg, #dceee2, #f3c9a4);
		background-size: 14px 14px;
	}

	.profile__body {
		padding: 12px 12px 14px;
	}

	.line {
		border-radius: 999px;
	}

	.line--name {
		height: 9px;
		width: 70%;
		background: var(--mock-ink);
	}

	.stars {
		margin-top: 8px;
		font-size: 12px;
		letter-spacing: 1px;
		color: var(--color-gold);
	}

	.stars span {
		color: rgba(36, 50, 41, 0.72);
		font-size: 9px;
		letter-spacing: 0;
	}

	.line--meta {
		margin-top: 7px;
		height: 5px;
		width: 55%;
		background: var(--mock-muted);
	}

	.profile__actions {
		display: flex;
		gap: 6px;
		margin-top: 11px;
	}

	.profile__actions span {
		flex: 1;
		height: 15px;
		border-radius: 999px;
		background: rgba(36, 50, 41, 0.08);
	}

	.profile__actions .accent {
		background: var(--color-gold);
	}

	.review {
		display: flex;
		gap: 7px;
		margin-top: 11px;
		align-items: center;
	}

	.review__avatar {
		width: 16px;
		height: 16px;
		flex-shrink: 0;
		border-radius: 999px;
		background: rgba(36, 50, 41, 0.1);
	}

	.review__lines {
		flex: 1;
	}

	.line--rev {
		height: 5px;
		width: 92%;
		background: var(--mock-muted);
	}

	.line--rev.short {
		margin-top: 4px;
		width: 60%;
	}

	/* Review toast: drifts in, holds, drifts out — the automation at work. */
	.toast {
		position: absolute;
		top: 18px;
		right: -46px;
		font-size: 10px;
		white-space: nowrap;
		color: white;
		background: var(--color-gold);
		border-radius: 999px;
		padding: 6px 11px;
		box-shadow: 0 10px 24px -8px rgba(200, 111, 74, 0.6);
		opacity: 0;
		animation: toast-in 6s ease-in-out infinite;
	}

	@keyframes toast-in {
		0%,
		12% {
			opacity: 0;
			transform: translateY(10px);
		}
		22%,
		68% {
			opacity: 1;
			transform: translateY(0);
		}
		80%,
		100% {
			opacity: 0;
			transform: translateY(-8px);
		}
	}

	@media (prefers-reduced-motion: reduce) {
		.toast {
			animation: none;
			opacity: 1;
			transform: none;
		}
	}

	@media (max-width: 420px) {
		.toast {
			right: -8px;
		}
	}
</style>
